{% render 'customer-shell-styles' %}

<style>
  .pw-meter {
    margin-top: 10px;
    display: flex; flex-direction: column; gap: 8px;
  }
  .pw-meter-bar {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 4px;
  }
  .pw-meter-bar span {
    height: 3px; background: var(--line-soft); border-radius: 2px;
    transition: background 0.25s;
  }
  .pw-meter-bar[data-strength="1"] span:nth-child(-n+1) { background: var(--error); }
  .pw-meter-bar[data-strength="2"] span:nth-child(-n+2) { background: #C68B5C; }
  .pw-meter-bar[data-strength="3"] span:nth-child(-n+3) { background: var(--clay); }
  .pw-meter-bar[data-strength="4"] span { background: var(--success); }
  .pw-meter-label {
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.14em;
    color: var(--muted);
  }
  .pw-meter-label strong { color: var(--ink-soft); font-weight: 500; }
  .match-row {
    margin-top: 8px;
    display: flex; align-items: center; gap: 8px;
    font-size: 12px; color: var(--muted);
  }
  .match-row.match { color: var(--success); }
  .match-row.no-match { color: var(--error); }
  .match-row svg { width: 14px; height: 14px; }
</style>

<div class="acct-shell">
  {% render 'customer-brand-pane',
    eyebrow: 'A fresh start',
    heading: 'A new <em>password</em>,<br>same small <em>house</em>.',
    lede: "Pick something memorable but not obvious. We'd suggest a phrase rather than a word — easier on you, harder on everyone else."
  %}

  <main class="form-pane">
    <div class="form-inner">

      <h2 class="pane-title">Set a new <em>password</em>.</h2>
      <p class="pane-sub">Use at least 8 characters. A mix of letters, a number, and a symbol works best.</p>

      {% form 'reset_customer_password', novalidate: 'novalidate' %}
        {%- if form.errors -%}
          <div class="form-errors">
            <ul>
              {%- for f in form.errors -%}
                <li>{{ form.errors.messages[f] }}</li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

        <div class="field">
          <div class="field-label-row"><span>New password</span></div>
          <div class="field-pw">
            <input type="password" class="field-input" name="customer[password]" placeholder="At least 8 characters" required minlength="8" autocomplete="new-password" id="reset-pw">
            <button type="button" class="toggle-pw" data-pw="reset-pw" aria-label="Show password">
              <svg fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12Z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
          <div class="pw-meter">
            <div class="pw-meter-bar" data-strength="0" id="pw-meter-bar">
              <span></span><span></span><span></span><span></span>
            </div>
            <div class="pw-meter-label">Strength: <strong id="pw-meter-label">enter a password</strong></div>
          </div>
        </div>

        <div class="field">
          <div class="field-label-row"><span>Confirm new password</span></div>
          <div class="field-pw">
            <input type="password" class="field-input" name="customer[password_confirmation]" placeholder="Repeat the password" required minlength="8" autocomplete="new-password" id="reset-pw-confirm">
            <button type="button" class="toggle-pw" data-pw="reset-pw-confirm" aria-label="Show password">
              <svg fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12Z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
          <div class="match-row" id="match-row">
            <svg fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/></svg>
            <span id="match-label">Passwords will be checked when you type</span>
          </div>
        </div>

        <button type="submit" class="submit-btn">Reset password <span class="arrow">→</span></button>

        <div class="form-foot">
          Remembered it after all? <a href="{{ routes.account_login_url }}">Back to sign in →</a>
        </div>
      {% endform %}

    </div>
  </main>
</div>

<script>
  // Show/hide password
  document.querySelectorAll('.toggle-pw').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.pw;
      const input = document.getElementById(id);
      if (!input) return;
      input.type = input.type === 'password' ? 'text' : 'password';
    });
  });

  // Strength + match
  const pw = document.getElementById('reset-pw');
  const pw2 = document.getElementById('reset-pw-confirm');
  const bar = document.getElementById('pw-meter-bar');
  const label = document.getElementById('pw-meter-label');
  const matchRow = document.getElementById('match-row');
  const matchLabel = document.getElementById('match-label');
  const labels = ['enter a password', 'too short', 'getting there', 'good', 'strong'];

  function checkStrength() {
    const v = pw.value;
    let score = 0;
    if (v.length >= 8) score++;
    if (v.length >= 12) score++;
    if (/[A-Z]/.test(v) && /[a-z]/.test(v)) score++;
    if (/\d/.test(v) && /[^A-Za-z0-9]/.test(v)) score++;
    if (v.length === 0) score = 0;
    bar.dataset.strength = score;
    label.textContent = labels[score];
  }

  function checkMatch() {
    if (!pw2.value) {
      matchRow.className = 'match-row';
      matchLabel.textContent = 'Passwords will be checked when you type';
      return;
    }
    if (pw.value === pw2.value) {
      matchRow.className = 'match-row match';
      matchLabel.textContent = 'Passwords match';
    } else {
      matchRow.className = 'match-row no-match';
      matchLabel.textContent = "Passwords don't match";
    }
  }

  pw.addEventListener('input', () => { checkStrength(); checkMatch(); });
  pw2.addEventListener('input', checkMatch);
</script>
