<style>
  body { min-height: 100vh; display: flex; flex-direction: column; }
  .pw-header {
    padding: 28px 40px;
    display: flex; align-items: center; justify-content: center;
    border-bottom: 1px solid var(--line);
  }
  .pw-header .logo {
    font-family: var(--font-heading); font-size: 26px; letter-spacing: 0.04em;
    color: var(--ink);
  }
  .pw-header .logo em { font-style: italic; font-weight: 300; }

  .pw-shell {
    flex: 1;
    display: grid; grid-template-columns: 1.1fr 1fr;
  }
  .pw-copy {
    padding: 80px 80px;
    display: flex; flex-direction: column; justify-content: center;
  }
  .pw-copy-inner { max-width: 520px; }
  .pw-badge {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 8px 14px; background: var(--cream); border-radius: 100px;
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.18em;
    font-weight: 500; color: var(--ink); margin-bottom: 32px;
  }
  .pw-badge .dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--clay);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
  .pw-copy h1 {
    font-family: var(--font-heading); font-weight: 400;
    font-size: clamp(48px, 6vw, 88px);
    line-height: 0.95; letter-spacing: -0.02em;
    margin-bottom: 30px;
  }
  .pw-copy h1 em { font-style: italic; font-weight: 300; color: var(--clay); }
  .pw-copy p {
    font-family: var(--font-heading); font-style: italic; font-weight: 300;
    font-size: 21px; line-height: 1.5; color: var(--ink-soft);
    max-width: 460px; margin-bottom: 22px;
  }
  .pw-copy p.body {
    font-style: normal; font-family: var(--font-body);
    font-size: 15.5px; line-height: 1.7; max-width: 480px;
  }
  .pw-copy p.body strong { color: var(--ink); font-weight: 500; }

  /* Newsletter form */
  .signup {
    margin-top: 24px;
    display: flex; flex-direction: column; gap: 14px;
    max-width: 480px;
  }
  .signup label {
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.18em;
    color: var(--muted); font-weight: 500;
  }
  .signup-row {
    display: flex; align-items: stretch;
    border: 1px solid var(--ink);
  }
  .signup-row input {
    flex: 1; background: transparent; border: none;
    padding: 16px 18px;
    font-family: var(--font-heading); font-style: italic; font-weight: 300;
    font-size: 18px; color: var(--ink); outline: none;
  }
  .signup-row button {
    background: var(--ink); color: var(--cream);
    border: none; cursor: pointer; padding: 0 26px;
    font-family: inherit; font-size: 12px; font-weight: 500;
    letter-spacing: 0.16em; text-transform: uppercase;
  }
  .signup-row button:hover { background: var(--clay-deep); }

  /* Password entry */
  .pw-entry {
    margin-top: 28px; padding-top: 24px;
    border-top: 1px dashed var(--line);
  }
  .pw-entry summary {
    list-style: none;
    cursor: pointer;
    font-size: 11.5px; color: var(--muted);
    text-transform: uppercase; letter-spacing: 0.16em;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .pw-entry summary::-webkit-details-marker { display: none; }
  .pw-entry summary svg { width: 12px; height: 12px; color: var(--clay); }
  .pw-entry summary:hover { color: var(--clay); }
  .pw-entry .pw-form {
    margin-top: 14px;
    display: flex;
    border: 1px solid var(--line); max-width: 360px;
    background: var(--paper);
  }
  .pw-entry .pw-form input {
    flex: 1; background: none; border: none; padding: 12px 14px;
    font-family: var(--font-heading); font-style: italic; font-weight: 300;
    font-size: 14px; outline: none;
  }
  .pw-entry .pw-form button {
    background: var(--ink-soft); color: var(--cream);
    border: none; cursor: pointer; padding: 0 18px;
    font-family: inherit; font-size: 11px;
    text-transform: uppercase; letter-spacing: 0.14em; font-weight: 500;
  }
  .pw-entry .errors {
    color: var(--error); font-size: 12px; margin-top: 8px;
  }

  .pw-pot {
    background:
      radial-gradient(ellipse at 60% 30%, rgba(255, 220, 190, 0.4), transparent 60%),
      linear-gradient(170deg, #C68B5C 0%, #8E4426 60%, #5C2A14 100%);
    position: relative; overflow: hidden;
    display: flex; align-items: center; justify-content: center;
  }
  .pw-pot svg {
    width: 70%; max-width: 380px; height: auto;
    filter: drop-shadow(0 40px 80px rgba(0,0,0,0.4));
  }
  .pw-pot .stamp {
    position: absolute; top: 48px; right: 48px;
    border: 2px solid var(--cream); color: var(--cream);
    padding: 12px 18px;
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.2em; font-weight: 500;
    transform: rotate(6deg); opacity: 0.8;
    text-align: center;
  }
  .pw-pot .stamp em {
    font-family: var(--font-heading); font-style: italic; font-weight: 300;
    display: block; font-size: 18px; margin-bottom: 4px; letter-spacing: 0.04em;
  }
  .pw-pot .signature {
    position: absolute; bottom: 60px; left: 48px;
    font-family: var(--font-accent); font-weight: 500;
    color: var(--cream); font-size: 26px; line-height: 1.2;
    transform: rotate(-3deg); opacity: 0.85;
    max-width: 260px;
  }

  footer.slim {
    border-top: 1px solid var(--line);
    padding: 22px 40px;
    font-size: 12px; color: var(--muted);
    display: flex; justify-content: space-between;
    flex-wrap: wrap; gap: 12px;
  }

  @media (max-width: 1024px) {
    .pw-shell { grid-template-columns: 1fr; }
    .pw-copy { padding: 50px 28px; }
    .pw-pot { min-height: 320px; padding: 60px 0; }
    .pw-pot svg { width: 200px; }
  }
</style>

<header class="pw-header">
  <a href="{{ shop.url }}" class="logo">
    {%- if settings.logo != blank -%}
      <img src="{{ settings.logo | image_url: width: 480 }}" alt="{{ shop.name }}" width="{{ settings.logo_width }}" height="{{ settings.logo_width | divided_by: settings.logo.aspect_ratio | round }}">
    {%- else -%}
      Kiln <em>&amp;</em> Clay
    {%- endif -%}
  </a>
</header>

<main class="pw-shell">
  <div class="pw-copy">
    <div class="pw-copy-inner">
      <span class="pw-badge"><span class="dot"></span>Opening soon · Spring 2026</span>

      <h1>A small <em>British</em> pottery house, almost <em>open</em>.</h1>

      <p>We're potting the first ninety-four pieces, photographing them in proper light, and writing the journal you'll read on launch day.</p>
      <p class="body">If you'd like a quiet email when the doors open — and £10 off your first order, because you waited — leave your address below.</p>

      {% form 'customer', class: 'signup' %}
        <input type="hidden" name="contact[tags]" value="prospect, password page">
        <label for="email">Email me when the shop opens</label>
        <div class="signup-row">
          <input id="email" type="email" name="contact[email]" placeholder="your@email.co.uk" required autocomplete="email">
          <button type="submit">Notify me</button>
        </div>
        {%- if form.posted_successfully? -%}
          <div style="font-size: 12px; color: var(--success); margin-top: 4px;">Thanks — we'll write to you on launch day.</div>
        {%- endif -%}
      {% endform %}

      {% form 'storefront_password', class: 'pw-entry' %}
        <details>
          <summary>
            <svg fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
            I have a store password
          </summary>
          <div class="pw-form">
            <input type="password" name="password" placeholder="Enter password" autocomplete="current-password">
            <button type="submit">Enter</button>
          </div>
          {%- if form.errors -%}
            <div class="errors">{{ form.errors | default_errors }}</div>
          {%- endif -%}
        </details>
      {% endform %}
    </div>
  </div>

  <div class="pw-pot">
    <div class="stamp">
      <em>Almost</em>
      Open · 2026
    </div>
    <svg viewBox="0 0 240 320" fill="none">
      <ellipse cx="120" cy="305" rx="100" ry="14" fill="rgba(0,0,0,0.32)"/>
      <path d="M44 105 L34 295 Q34 305 46 305 L194 305 Q206 305 206 295 L196 105 Z" fill="#A06840" stroke="#3A1A0E" stroke-width="0.8" opacity="0.92"/>
      <ellipse cx="120" cy="105" rx="78" ry="16" fill="#7A4528"/>
      <ellipse cx="120" cy="105" rx="72" ry="11" fill="#2D1408"/>
      <path d="M120 95 Q90 50 100 20 Q105 5 115 12 Q120 20 120 95" fill="#5F6A55" opacity="0.85"/>
      <path d="M120 95 Q150 60 145 30 Q140 15 130 22 Q120 35 120 95" fill="#7C8B6F" opacity="0.85"/>
    </svg>
    <div class="signature">back at the wheel —<br>— Margaret</div>
  </div>
</main>

<footer class="slim">
  <div>© {{ 'now' | date: '%Y' }} {{ shop.name }} · {{ shop.address.city }}</div>
  <div>{{ powered_by_link }}</div>
</footer>
