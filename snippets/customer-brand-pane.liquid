<aside class="brand-pane">
  <div class="brand-top">
    <div class="eb">{{ eyebrow | default: 'The Slow List' }}</div>
    <h1>{{ heading | default: 'A small <em>account</em>,<br>for a small <em>house</em>.' }}</h1>
    <p class="lede">{{ lede | default: "Order tracking, saved addresses, your wishlist, and a fortnightly newsletter you can opt out of any time. No data we don't need." }}</p>
  </div>

  <svg class="brand-pot" viewBox="0 0 240 320" fill="none">
    <ellipse cx="120" cy="305" rx="100" ry="14" fill="rgba(0,0,0,0.32)"/>
    <path d="M44 105 L34 295 Q34 305 46 305 L194 305 Q206 305 206 295 L196 105 Z" fill="#A06840" stroke="#3A1A0E" stroke-width="0.8" opacity="0.9"/>
    <ellipse cx="120" cy="105" rx="78" ry="16" fill="#7A4528"/>
    <ellipse cx="120" cy="105" rx="72" ry="11" fill="#2D1408"/>
    <path d="M44 145 L196 145" stroke="rgba(46, 14, 4, 0.4)" stroke-width="0.6"/>
    <path d="M42 200 L198 200" stroke="rgba(46, 14, 4, 0.32)" stroke-width="0.5"/>
  </svg>

  <div class="brand-bottom">
    <div class="brand-perk">
      <div class="num">01</div>
      <div class="lab"><strong>Track every order</strong>From kiln to your door, in one view.</div>
    </div>
    <div class="brand-perk">
      <div class="num">02</div>
      <div class="lab"><strong>Save your wishlist</strong>Across devices. Persists when you log in.</div>
    </div>
    <div class="brand-perk">
      <div class="num">03</div>
      <div class="lab"><strong>Faster checkout</strong>Saved addresses for next time.</div>
    </div>
    <div class="brand-perk">
      <div class="num">04</div>
      <div class="lab"><strong>Studio invitations</strong>First access to open-studio days.</div>
    </div>
