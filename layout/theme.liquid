<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="{{ settings.colour_paper }}">
  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {%- comment -%} Fonts served from the Shopify CDN via the theme font picker {%- endcomment -%}
  <style>
    {{ settings.heading_font | font_face: font_display: 'swap' }}
    {{ settings.heading_font | font_modify: 'weight', '300' | font_face: font_display: 'swap' }}
    {{ settings.heading_font | font_modify: 'weight', '500' | font_face: font_display: 'swap' }}
    {{ settings.heading_font | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}
    {{ settings.heading_font | font_modify: 'weight', '300' | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}
    {{ settings.body_font | font_face: font_display: 'swap' }}
    {{ settings.body_font | font_modify: 'weight', '500' | font_face: font_display: 'swap' }}
    {{ settings.accent_font | font_face: font_display: 'swap' }}
    {{ settings.accent_font | font_modify: 'weight', '500' | font_face: font_display: 'swap' }}
  </style>

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  <style>
    :root {
      --cream: {{ settings.colour_cream }};
      --cream-deep: {{ settings.colour_cream_deep }};
      --paper: {{ settings.colour_paper }};
      --ink: {{ settings.colour_ink }};
      --ink-soft: {{ settings.colour_ink_soft }};
      --muted: {{ settings.colour_muted }};
      --line: {{ settings.colour_line }};
      --line-soft: {{ settings.colour_line_soft }};
      --clay: {{ settings.colour_clay }};
      --clay-deep: {{ settings.colour_clay_deep }};
      --sage: #7C8B6F;
      --moss: #4F5B45;
      --bone: #E5DCC8;
      --success: #4F5B45;
      --error: #B23838;
      --font-heading: {{ settings.heading_font.family }}, {{ settings.heading_font.fallback_families }};
      --font-body: {{ settings.body_font.family }}, {{ settings.body_font.fallback_families }};
      --font-accent: {{ settings.accent_font.family }}, {{ settings.accent_font.fallback_families }};
    }
  </style>

  {{ content_for_header }}
</head>

<body class="template-{{ template | replace: '.', '-' | handle }}">

  <a class="skip-link" href="#MainContent">{{ 'accessibility.skip_to_text' | t }}</a>

  {% section 'announcement' %}
  {% section 'header' %}

  <main id="MainContent" role="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {% comment %} Globals — rendered once per page {% endcomment %}
  {% render 'cart-drawer' %}
  {% render 'mobile-nav' %}
  {% render 'toast-stack' %}
  {% render 'cookie-consent' %}

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
