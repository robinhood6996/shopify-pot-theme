<style>
  #shopify-section-{{ section.id }} .letter {
    max-width: 760px; margin: 0 auto;
    padding: 120px 40px;
    text-align: left;
  }
  #shopify-section-{{ section.id }} .letter p {
    font-size: 19px; line-height: 1.75; color: var(--ink);
    margin-bottom: 24px;
  }
  #shopify-section-{{ section.id }} .letter p:first-of-type::first-letter {
    font-family: var(--font-heading); font-style: italic; font-weight: 300;
    font-size: 88px; line-height: 0.85;
    float: left; margin: 8px 14px 0 0; color: var(--clay);
  }
  #shopify-section-{{ section.id }} .letter strong { color: var(--ink); font-weight: 500; }
  #shopify-section-{{ section.id }} .letter em {
    font-family: var(--font-heading); font-style: italic; font-weight: 300;
  }
  @media (max-width: 1024px) {
    #shopify-section-{{ section.id }} .letter { padding: 80px 24px; }
    #shopify-section-{{ section.id }} .letter p { font-size: 17px; }
  }
</style>

<section class="letter">
  {%- assign paragraphs = section.settings.body | newline_to_br | split: '<br />' -%}
  {%- for para in paragraphs -%}
    {%- if para != blank -%}
      <p>{{ para | strip }}</p>
    {%- endif -%}
  {%- endfor -%}
</section>

{% schema %}
{
  "name": "About: founder letter",
  "settings": [
    { "type": "textarea", "id": "body", "label": "Letter body (paragraphs separated by blank lines)", "info": "You can use <em> and <strong> inline." }
  ],
  "presets": [{ "name": "About: founder letter", "category": "About" }]
}
{% endschema %}
