<style>
  #shopify-section-{{ section.id }} .press {
    background: var(--ink); color: var(--cream);
    padding: 80px 40px; text-align: center;
  }
  #shopify-section-{{ section.id }} .press .eb { color: var(--clay); margin-bottom: 36px; font-size: 11px; text-transform: uppercase; letter-spacing: 0.22em; font-weight: 500; }
  #shopify-section-{{ section.id }} .press-row {
    display: flex; align-items: center; justify-content: center;
    gap: 60px; flex-wrap: wrap;
    max-width: 1100px; margin: 0 auto;
  }
  #shopify-section-{{ section.id }} .press-name {
    font-family: var(--font-heading); font-weight: 300;
    font-size: 22px; letter-spacing: 0.05em;
    color: var(--bone); opacity: 0.7;
    transition: opacity 0.2s;
    text-decoration: none;
  }
  #shopify-section-{{ section.id }} .press-name:hover { opacity: 1; color: var(--cream); }
  #shopify-section-{{ section.id }} .press-name.italic { font-style: italic; }
  #shopify-section-{{ section.id }} .press-name.upper { text-transform: uppercase; letter-spacing: 0.25em; font-size: 14px; font-weight: 500; }
  @media (max-width: 1024px) {
    #shopify-section-{{ section.id }} .press-row { gap: 30px; }
  }
</style>

<section class="press">
  {%- if section.settings.eyebrow != blank -%}
    <div class="eb">{{ section.settings.eyebrow }}</div>
  {%- endif -%}
  <div class="press-row">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.url | default: '#' }}" class="press-name {{ block.settings.style }}" {{ block.shopify_attributes }}>{{ block.settings.name }}</a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Press strip",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "As featured in" }
  ],
  "blocks": [
    {
      "type": "publication",
      "name": "Publication",
      "settings": [
        { "type": "text", "id": "name", "label": "Publication name" },
        { "type": "url",  "id": "url",  "label": "Link (optional)" },
        {
          "type": "select", "id": "style", "label": "Style",
          "options": [
            { "value": "italic", "label": "Italic Fraunces" },
            { "value": "upper",  "label": "Uppercase DM Sans" }
          ],
          "default": "italic"
        }
      ]
    }
  ],
  "presets": [{ "name": "Press strip", "category": "About" }]
}
{% endschema %}
