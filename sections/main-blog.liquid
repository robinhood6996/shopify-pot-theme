{% paginate blog.articles by 12 %}

<style>
  .blog-hero {
    max-width: 1400px; margin: 0 auto;
    padding: 60px 40px 50px;
    display: grid; grid-template-columns: 1.5fr 1fr;
    gap: 80px; align-items: end;
    border-bottom: 1px solid var(--line);
  }
  .blog-hero .eyebrow {
    color: var(--clay); margin-bottom: 26px;
    display: flex; align-items: center; gap: 14px;
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.22em; font-weight: 500;
  }
  .blog-hero .eyebrow::before { content: ''; width: 32px; height: 1px; background: var(--clay); }
  .blog-hero h1 {
    font-family: var(--font-heading); font-weight: 400;
    font-size: clamp(56px, 8vw, 110px); line-height: 0.95; letter-spacing: -0.02em;
  }
  .blog-hero h1 em { font-style: italic; font-weight: 300; color: var(--clay); }
  .blog-hero p {
    font-family: var(--font-heading); font-style: italic; font-weight: 300;
    font-size: 19px; line-height: 1.5; color: var(--ink-soft); max-width: 460px;
  }
  .blog-hero .meta {
    display: flex; gap: 28px; flex-wrap: wrap;
    margin-top: 28px; padding-top: 22px; border-top: 1px solid var(--line);
  }
  .blog-hero .meta-item .v {
    font-family: var(--font-heading); font-style: italic; font-weight: 300;
    font-size: 24px; color: var(--clay); line-height: 1;
  }
  .blog-hero .meta-item .l {
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.16em;
    color: var(--muted); margin-top: 6px;
  }

  .blog-filter-bar {
    max-width: 1400px; margin: 0 auto;
    padding: 24px 40px;
    border-bottom: 1px solid var(--line);
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
    background: var(--paper);
    position: sticky; top: 78px; z-index: 50;
  }
  .blog-filter-chip {
    border: 1px solid var(--line); padding: 8px 14px; border-radius: 100px;
    font-size: 12.5px; background: transparent; color: var(--ink-soft);
    transition: all 0.2s; text-decoration: none;
    display: inline-flex; align-items: center; gap: 6px;
  }
  .blog-filter-chip:hover { border-color: var(--ink); color: var(--ink); }
  .blog-filter-chip.active { background: var(--ink); color: var(--cream); border-color: var(--ink); }
  .blog-filter-chip .ct {
    font-family: var(--font-heading); font-style: italic; font-weight: 300;
    margin-left: 6px; opacity: 0.75; font-size: 13px;
  }

  .blog-featured { max-width: 1400px; margin: 0 auto; padding: 60px 40px; }
  .blog-featured-card {
    display: grid; grid-template-columns: 1.2fr 1fr;
    gap: 60px; align-items: stretch;
    background: var(--cream); border-radius: 2px; overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s;
    text-decoration: none; color: inherit;
  }
  .blog-featured-card:hover { transform: translateY(-4px); box-shadow: 0 30px 70px rgba(26, 20, 14, 0.06); }
  .blog-featured-img {
    position: relative; min-height: 480px;
    background: linear-gradient(140deg, #C97B5E, #6F3A23); overflow: hidden;
  }
  .blog-featured-img img { width: 100%; height: 100%; object-fit: cover; }
  .blog-featured-tag {
    position: absolute; top: 24px; left: 24px;
    background: var(--ink); color: var(--cream);
    padding: 7px 14px; font-size: 11px; text-transform: uppercase; letter-spacing: 0.18em; font-weight: 500;
    z-index: 3; display: inline-flex; align-items: center; gap: 8px;
  }
  .blog-featured-tag::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--clay); }
  .blog-featured-text {
    padding: 50px 50px 50px 0;
    display: flex; flex-direction: column; justify-content: center;
  }
  .blog-featured-text .meta {
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.16em;
    color: var(--clay); font-weight: 500; margin-bottom: 16px;
  }
  .blog-featured-text h2 {
    font-family: var(--font-heading); font-weight: 400;
    font-size: clamp(34px, 4vw, 52px); line-height: 1.1;
    letter-spacing: -0.02em; margin-bottom: 18px;
  }
  .blog-featured-text .dek {
    font-family: var(--font-heading); font-style: italic; font-weight: 300;
    font-size: 18px; line-height: 1.5; color: var(--ink-soft);
    margin-bottom: 24px; max-width: 520px;
  }
  .blog-featured-text .author {
    font-size: 13px; color: var(--ink-soft);
    display: flex; align-items: center; gap: 10px; margin-bottom: 24px;
  }
  .blog-featured-text .author .av {
    width: 28px; height: 28px; border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, #C68B5C, #5C2A14);
  }
  .blog-featured-text .author strong { font-family: var(--font-heading); font-size: 14px; color: var(--ink); font-weight: 400; }
  .blog-featured-text .read-cta {
    align-self: flex-start;
    display: inline-flex; align-items: center; gap: 12px;
    background: var(--ink); color: var(--cream);
    padding: 16px 24px; font-size: 12px; text-transform: uppercase; letter-spacing: 0.16em; font-weight: 500;
  }

  .articles-list { max-width: 1400px; margin: 0 auto; padding: 30px 40px 50px; }
  .articles-head {
    display: flex; align-items: baseline; justify-content: space-between;
    flex-wrap: wrap; gap: 16px; margin-bottom: 36px;
  }
  .articles-head h2 {
    font-family: var(--font-heading); font-size: clamp(28px, 3.5vw, 38px);
    font-weight: 400; line-height: 1.1;
  }
  .articles-head h2 em { font-style: italic; font-weight: 300; color: var(--clay); }

  .articles-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 50px 30px; }
  .article-card { cursor: pointer; text-decoration: none; color: inherit; }
  .article-card-img {
    aspect-ratio: 4 / 3; border-radius: 2px;
    overflow: hidden; margin-bottom: 18px; background: var(--cream-deep);
  }
  .article-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
  .article-card:hover .article-card-img img { transform: scale(1.04); }
  .article-card-meta {
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.16em;
    color: var(--clay); font-weight: 500; margin-bottom: 12px;
  }
  .article-card-meta .sep { color: var(--muted); margin: 0 8px; }
  .article-card h3 {
    font-family: var(--font-heading); font-size: 24px; font-weight: 400;
    line-height: 1.2; margin-bottom: 10px;
    transition: color 0.2s; letter-spacing: -0.01em;
  }
  .article-card:hover h3 { color: var(--clay); }
  .article-card .excerpt { color: var(--ink-soft); font-size: 14px; line-height: 1.6; margin-bottom: 14px; }
  .article-card .author {
    font-size: 11.5px; color: var(--muted);
    display: flex; align-items: center; gap: 8px; letter-spacing: 0.04em;
  }
  .article-card .author .av {
    width: 20px; height: 20px; border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, #C68B5C, #5C2A14);
  }
  .article-card .author strong { color: var(--ink); font-weight: 400; font-family: var(--font-heading); font-size: 13px; }

  .blog-empty { grid-column: 1 / -1; text-align: center; padding: 80px 20px; color: var(--muted); font-family: var(--font-heading); font-style: italic; font-size: 22px; }

  .blog-pagination {
    max-width: 1400px; margin: 0 auto;
    padding: 60px 40px 80px;
    display: flex; justify-content: center; align-items: center; gap: 8px;
  }
  .blog-pagination a, .blog-pagination span.current {
    background: transparent; border: 1px solid var(--line);
    width: 40px; height: 40px;
    display: inline-flex; align-items: center; justify-content: center;
    font-family: var(--font-heading); font-size: 14px; color: var(--ink-soft);
    transition: all 0.2s; text-decoration: none;
  }
  .blog-pagination a:hover { border-color: var(--ink); color: var(--ink); }
  .blog-pagination .current { background: var(--ink); color: var(--cream); border-color: var(--ink); }
  .blog-pagination .nav-arrow {
    width: auto; padding: 0 18px; font-family: inherit; font-size: 11px;
    text-transform: uppercase; letter-spacing: 0.14em; font-weight: 500;
    display: inline-flex; align-items: center; gap: 8px;
  }

  @media (max-width: 1024px) {
    .blog-hero { grid-template-columns: 1fr; gap: 30px; padding: 40px 24px; }
    .blog-filter-bar { padding: 18px 24px; }
    .blog-featured { padding: 40px 24px; }
    .blog-featured-card { grid-template-columns: 1fr; }
    .blog-featured-img { min-height: 280px; aspect-ratio: 16/9; }
    .blog-featured-text { padding: 32px; }
    .articles-list { padding: 30px 24px; }
    .articles-grid { grid-template-columns: repeat(2, 1fr); gap: 40px 20px; }
  }
  @media (max-width: 600px) { .articles-grid { grid-template-columns: 1fr; } }
</style>

<nav class="breadcrumb">
  <a href="{{ routes.root_url }}">Home</a><span class="sep">/</span>
  <span class="current">{{ blog.title }}</span>
</nav>

<section class="blog-hero">
  <div>
    <div class="eyebrow">{{ blog.title }}</div>
    <h1>{{ section.settings.heading | default: 'Slow notes on plants, pots, and the rooms' }} <em>{{ section.settings.heading_italic | default: 'in between' }}</em>.</h1>
  </div>
  <div>
    <p>{{ section.settings.subtext | default: "Twice a month. Buying guides without the affiliate noise, plant care without the panic, and the occasional letter from one of our makers' studios." }}</p>
    <div class="meta">
      <div class="meta-item">
        <div class="v">{{ blog.articles_count }}</div>
        <div class="l">{% if blog.articles_count == 1 %}Article{% else %}Articles{% endif %}</div>
      </div>
      <div class="meta-item">
        <div class="v">{{ blog.all_tags.size }}</div>
        <div class="l">Categories</div>
      </div>
    </div>
  </div>
</section>

{%- if blog.all_tags.size > 0 -%}
  <div class="blog-filter-bar">
    <a href="{{ blog.url }}" class="blog-filter-chip {% unless current_tags %}active{% endunless %}">All <span class="ct">{{ blog.articles_count }}</span></a>
    {%- for tag in blog.all_tags -%}
      <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="blog-filter-chip {% if current_tags contains tag %}active{% endif %}">{{ tag }}</a>
    {%- endfor -%}
  </div>
{%- endif -%}

{%- if blog.articles.size > 0 and current_page == 1 and current_tags == empty -%}
  {%- assign lead = blog.articles | first -%}
  <section class="blog-featured">
    <a href="{{ lead.url }}" class="blog-featured-card">
      <div class="blog-featured-img">
        <span class="blog-featured-tag">Latest</span>
        {%- if lead.image -%}
          <img src="{{ lead.image | image_url: width: 1200 }}" alt="{{ lead.image.alt | default: lead.title | escape }}" width="1200" height="{{ 1200 | divided_by: lead.image.aspect_ratio | round }}" loading="eager">
        {%- endif -%}
      </div>
      <div class="blog-featured-text">
        <div class="meta">
          {{ lead.tags | first | default: blog.title }}
          <span style="margin: 0 8px; color: var(--muted);">·</span>
          {%- assign mins = lead.content | strip_html | split: ' ' | size | divided_by: 200 | at_least: 1 -%}
          {{ mins }} min read
          <span style="margin: 0 8px; color: var(--muted);">·</span>
          {{ lead.published_at | date: "%-d %B %Y" }}
        </div>
        <h2>{{ lead.title }}</h2>
        {%- if lead.excerpt != blank -%}
          <p class="dek">{{ lead.excerpt | strip_html | truncate: 200 }}</p>
        {%- endif -%}
        {%- if lead.author -%}
          <div class="author">
            <span class="av"></span>
            <span>by <strong>{{ lead.author }}</strong></span>
          </div>
        {%- endif -%}
        <span class="read-cta">{{ 'blogs.article.read_more' | t | default: 'Read the article' }} <span style="font-family:var(--font-heading);font-style:italic;font-weight:300;font-size:16px;">→</span></span>
      </div>
    </a>
  </section>
{%- endif -%}

<section class="articles-list">
  {%- if blog.articles.size > 1 or current_page > 1 or current_tags != empty -%}
    <div class="articles-head">
      <h2>From the <em>journal</em>{%- if current_tags %} <span style="color:var(--muted);font-style:italic;font-family:var(--font-heading);font-weight:300;">· {{ current_tags | join: ', ' }}</span>{%- endif -%}</h2>
    </div>
  {%- endif -%}
  <div class="articles-grid">
    {%- if blog.articles.size == 0 -%}
      <div class="blog-empty">No articles yet — check back soon.</div>
    {%- else -%}
      {%- for article in blog.articles -%}
        {%- if forloop.first and current_page == 1 and current_tags == empty -%}{%- continue -%}{%- endif -%}
        {%- assign mins = article.content | strip_html | split: ' ' | size | divided_by: 200 | at_least: 1 -%}
        <a href="{{ article.url }}" class="article-card">
          <div class="article-card-img">
            {%- if article.image -%}
              <img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.image.alt | default: article.title | escape }}" width="600" height="{{ 600 | divided_by: article.image.aspect_ratio | round }}" loading="lazy">
            {%- endif -%}
          </div>
          <div class="article-card-meta">
            {{ article.tags | first | default: blog.title }}<span class="sep">·</span>{{ mins }} min<span class="sep">·</span>{{ article.published_at | date: "%-d %b %Y" }}
          </div>
          <h3>{{ article.title }}</h3>
          {%- if article.excerpt != blank -%}
            <p class="excerpt">{{ article.excerpt | strip_html | truncate: 140 }}</p>
          {%- endif -%}
          {%- if article.author -%}
            <div class="author"><span class="av"></span><span><strong>{{ article.author }}</strong></span></div>
          {%- endif -%}
        </a>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{%- if paginate.pages > 1 -%}
  <div class="blog-pagination">
    {%- if paginate.previous %}<a href="{{ paginate.previous.url }}" class="nav-arrow"><svg fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24" style="width:14px;height:14px;"><path d="M19 12H5m6-6-6 6 6 6"/></svg> {{ 'general.pagination.previous' | t | default: 'Newer' }}</a>{%- endif -%}
    {%- for part in paginate.parts -%}
      {%- if part.is_link %}<a href="{{ part.url }}">{{ part.title }}</a>{%- elsif part.title == paginate.current_page %}<span class="current">{{ part.title }}</span>{%- else %}<span>{{ part.title }}</span>{%- endif -%}
    {%- endfor -%}
    {%- if paginate.next %}<a href="{{ paginate.next.url }}" class="nav-arrow">{{ 'general.pagination.next' | t | default: 'Older' }} <svg fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24" style="width:14px;height:14px;"><path d="M5 12h14m-6-6 6 6-6 6"/></svg></a>{%- endif -%}
  </div>
{%- endif -%}

{% endpaginate %}

{% schema %}
{
  "name": "Blog posts",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Slow notes on plants, pots, and the rooms" },
    { "type": "text", "id": "heading_italic", "label": "Heading italic part", "default": "in between" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Twice a month. Buying guides without the affiliate noise, plant care without the panic, and the occasional letter from one of our makers' studios." }
  ]
}
{% endschema %}
