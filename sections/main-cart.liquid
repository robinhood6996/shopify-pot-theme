<style>
  .cart-page {
    max-width: 1280px; margin: 0 auto;
    padding: 0 40px 100px;
  }
  .cart-page .page-head {
    padding: 50px 0 24px;
    display: flex; justify-content: space-between; align-items: end;
    gap: 30px; flex-wrap: wrap;
  }
  .cart-page .page-head .eyebrow { color: var(--clay); margin-bottom: 14px; }
  .cart-page h1 {
    font-family: var(--font-heading); font-weight: 400;
    font-size: clamp(48px, 6vw, 80px); line-height: 1; letter-spacing: -0.02em;
  }
  .cart-page h1 em { font-style: italic; font-weight: 300; color: var(--clay); }
  .cart-page h1 .count {
    font-family: var(--font-heading); font-style: italic; font-weight: 300;
    color: var(--muted); font-size: 0.5em; margin-left: 16px;
  }
  .cart-page .continue {
    font-size: 12.5px; color: var(--ink-soft);
    text-transform: uppercase; letter-spacing: 0.12em;
    border-bottom: 1px solid var(--ink-soft); padding-bottom: 4px;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .cart-page .continue:hover { color: var(--clay); border-color: var(--clay); }

  .cart-ship {
    margin-top: 16px; margin-bottom: 50px;
    background: var(--cream); border: 1px solid var(--line-soft);
    padding: 18px 22px;
    display: grid; grid-template-columns: auto 1fr; gap: 20px; align-items: center;
  }
  .cart-ship .icon {
    width: 40px; height: 40px; border-radius: 50%;
    background: var(--paper); border: 1px solid var(--line);
    display: flex; align-items: center; justify-content: center;
    color: var(--success); flex-shrink: 0;
  }
  .cart-ship .ship-text { display: flex; flex-direction: column; gap: 8px; }
  .cart-ship .ship-text .head {
    font-family: var(--font-heading); font-style: italic; font-weight: 300;
    font-size: 17px; color: var(--ink);
  }
  .cart-ship .ship-text .head strong { font-style: normal; font-weight: 400; }

  .cart-layout {
    display: grid; grid-template-columns: 1.6fr 1fr;
    gap: 60px; align-items: start;
  }

  .items-head {
    display: grid; grid-template-columns: 110px 1fr 100px;
    padding-bottom: 14px; gap: 24px;
    border-bottom: 1px solid var(--line);
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.18em;
    color: var(--muted); font-weight: 500;
  }
  .items-head .col-r { text-align: right; }

  .item {
    display: grid; grid-template-columns: 110px 1fr 100px;
    gap: 24px; padding: 28px 0;
    border-bottom: 1px solid var(--line-soft);
    align-items: start;
  }
  .item-img {
    width: 110px; height: 132px;
    border-radius: 2px; overflow: hidden;
    background: var(--cream);
  }
  .item-img img { width: 100%; height: 100%; object-fit: cover; }
  .item-info { display: flex; flex-direction: column; gap: 6px; }
  .item-info .nm {
    font-family: var(--font-heading); font-size: 20px; font-weight: 400;
    line-height: 1.2; color: var(--ink);
  }
  .item-info .var {
    font-size: 13px; color: var(--ink-soft); letter-spacing: 0.04em; line-height: 1.4;
  }
  .item-info .controls {
    margin-top: 14px; display: flex; align-items: center; gap: 22px; flex-wrap: wrap;
  }
  .qty-cart {
    display: flex; align-items: center;
    border: 1px solid var(--line); height: 36px; background: var(--paper);
  }
  .qty-cart button {
    background: none; border: none; cursor: pointer;
    width: 32px; height: 100%;
    color: var(--ink);
    font-family: var(--font-heading); font-size: 16px; font-weight: 300;
  }
  .qty-cart input {
    width: 32px; text-align: center;
    border: none; background: none; outline: none;
    font-family: var(--font-heading); font-size: 14px; color: var(--ink); height: 100%;
  }
  .item-remove {
    background: none; border: none; cursor: pointer;
    color: var(--muted);
    font-family: inherit; font-size: 12px;
    text-transform: uppercase; letter-spacing: 0.1em;
    padding: 0; transition: color 0.2s;
  }
  .item-remove:hover { color: var(--clay); }
  .item-price { text-align: right; font-family: var(--font-heading); font-size: 17px; }
  .item-price .unit {
    font-size: 11px; color: var(--muted);
    text-transform: uppercase; letter-spacing: 0.1em;
    margin-top: 4px; font-family: var(--font-body);
  }

  .summary {
    position: sticky; top: 100px;
    background: var(--paper); border: 1px solid var(--line);
    padding: 32px;
  }
  .summary h2 {
    font-family: var(--font-heading); font-size: 24px; font-weight: 400;
    margin-bottom: 24px; line-height: 1;
    padding-bottom: 22px; border-bottom: 1px solid var(--line-soft);
  }
  .summary h2 em { font-style: italic; font-weight: 300; color: var(--clay); }
  .sum-row {
    display: flex; justify-content: space-between; align-items: baseline;
    padding: 10px 0; font-size: 14px;
  }
  .sum-row .label { color: var(--ink-soft); }
  .sum-row .val { color: var(--ink); font-variant-numeric: tabular-nums; }
  .sum-row.shipping .val { color: var(--success); font-weight: 500; }
  .sum-total {
    display: flex; justify-content: space-between; align-items: baseline;
    padding: 22px 0 12px; margin-top: 8px;
    border-top: 1px solid var(--line);
  }
  .sum-total .label {
    font-size: 13px; text-transform: uppercase; letter-spacing: 0.16em;
    color: var(--ink); font-weight: 500;
  }
  .sum-total .total-val {
    font-family: var(--font-heading); font-size: 32px;
    font-variant-numeric: tabular-nums;
  }
  .sum-tax {
    text-align: right; font-size: 11px; color: var(--muted);
    margin-bottom: 16px;
  }
  .checkout-btn {
    width: 100%;
    background: var(--ink); color: var(--cream);
    border: none; cursor: pointer;
    padding: 18px;
    font-family: inherit; font-size: 13px; font-weight: 500;
    letter-spacing: 0.16em; text-transform: uppercase;
    transition: background 0.2s;
    display: inline-flex; align-items: center; justify-content: center; gap: 12px;
    margin-bottom: 14px;
    text-decoration: none;
  }
  .checkout-btn:hover { background: var(--clay-deep); }
  .checkout-btn .arrow { font-family: var(--font-heading); font-style: italic; font-weight: 300; font-size: 16px; }

  .cart-empty {
    text-align: center;
    padding: 100px 24px;
    max-width: 720px; margin: 0 auto;
  }
  .cart-empty .icon {
    width: 88px; height: 88px;
    margin: 0 auto 28px;
    background: var(--cream); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: var(--clay);
  }
  .cart-empty .icon svg { width: 36px; height: 36px; }
  .cart-empty h2 {
    font-family: var(--font-heading); font-size: 44px; font-weight: 400;
    line-height: 1.1; margin-bottom: 16px;
  }
  .cart-empty h2 em { font-style: italic; font-weight: 300; color: var(--clay); }
  .cart-empty p {
    font-family: var(--font-heading); font-style: italic; font-weight: 300;
    font-size: 19px; color: var(--ink-soft);
    max-width: 480px; margin: 0 auto 32px;
  }
  .cart-empty a {
    display: inline-flex; align-items: center; gap: 10px;
    background: var(--ink); color: var(--cream);
    padding: 16px 28px;
    font-size: 13px; text-transform: uppercase; letter-spacing: 0.15em; font-weight: 500;
  }
  .cart-empty a:hover { background: var(--clay-deep); }

  @media (max-width: 1024px) {
    .cart-layout { grid-template-columns: 1fr; gap: 40px; }
    .summary { position: static; }
    .cart-page { padding: 0 24px 60px; }
  }
</style>

{%- if cart.item_count == 0 -%}
  <div class="cart-empty">
    <div class="icon">
      <svg fill="none" stroke="currentColor" stroke-width="1.4" viewBox="0 0 24 24">
        <path d="M5 7h14l-1.5 12h-11Z"/>
        <path d="M9 7V5a3 3 0 0 1 6 0v2"/>
      </svg>
    </div>
    <h2 class="display">Your basket is <em>empty</em>.</h2>
    <p>Quiet, for now. Browse the shop, or pick up where you left off — your wishlist is still here.</p>
    <a href="{{ routes.collections_url }}">
      Shop the collection
      <span style="font-family: var(--font-heading); font-style: italic; font-weight: 300;">→</span>
    </a>
  </div>
{%- else -%}

<div class="cart-page">

  <div class="page-head">
    <div>
      <div class="eyebrow">Step 1 of 3</div>
      <h1>Your <em>basket</em><span class="count">{{ cart.item_count }} {% if cart.item_count == 1 %}piece{% else %}pieces{% endif %}</span></h1>
    </div>
    <a href="{{ routes.all_products_collection_url | default: routes.collections_url }}" class="continue">
      <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><path d="M19 12H5m6-6-6 6 6 6"/></svg>
      Continue shopping
    </a>
  </div>

  {%- if settings.show_free_shipping_bar -%}
    {%- assign threshold_cents = settings.free_shipping_threshold | times: 100 -%}
    <div class="cart-ship">
      <div class="icon">
        <svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="m9 12 2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
      </div>
      <div class="ship-text">
        <div class="head">
          {%- if cart.total_price >= threshold_cents -%}
            <strong>{{ 'cart.general.free_shipping_notice_html' | t | default: "You've qualified for free UK delivery." }}</strong>
          {%- else -%}
            {{ 'cart.general.free_shipping_progress_html' | t: amount: threshold_cents | minus: cart.total_price | money | default: "Add more for free UK delivery." }}
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  <form action="{{ routes.cart_url }}" method="post" id="cart-form">
    <div class="cart-layout">

      <main>
        <div class="items-head">
          <span></span>
          <span>Item</span>
          <span class="col-r">Total</span>
        </div>

        {%- for item in cart.items -%}
          <div class="item" data-key="{{ item.key }}">
            <a href="{{ item.url }}" class="item-img">
              {%- if item.image -%}
                <img src="{{ item.image | image_url: width: 220 }}" alt="{{ item.title | escape }}" width="220" height="{{ 220 | divided_by: item.image.aspect_ratio | round }}" loading="lazy">
              {%- endif -%}
            </a>
            <div class="item-info">
              <a href="{{ item.url }}" class="nm">{{ item.product.title }}</a>
              {%- unless item.variant.title == 'Default Title' -%}
                <div class="var">{{ item.variant.title }}</div>
              {%- endunless -%}
              <div class="controls">
                <div class="qty-cart" data-cart-qty="{{ item.key }}">
                  <button type="button" data-step="-1" aria-label="Decrease">−</button>
                  <input type="text" name="updates[{{ item.key }}]" value="{{ item.quantity }}" readonly aria-label="Quantity">
                  <button type="button" data-step="1" aria-label="Increase">+</button>
                </div>
                <button type="button" class="item-remove" data-cart-remove="{{ item.key }}">{{ 'cart.general.remove' | t | default: 'Remove' }}</button>
              </div>
            </div>
            <div class="item-price">
              {{ item.final_line_price | money }}
              {%- if item.quantity > 1 -%}
                <div class="unit">{{ item.final_price | money }} each</div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </main>

      <aside class="summary">
        <h2>Order <em>summary</em></h2>
        <div class="sum-row">
          <span class="label">{{ 'cart.general.subtotal' | t | default: 'Subtotal' }} · {{ cart.item_count }} items</span>
          <span class="val">{{ cart.items_subtotal_price | money }}</span>
        </div>
        {%- for d in cart.cart_level_discount_applications -%}
          <div class="sum-row" style="color: var(--clay);">
            <span class="label">{{ d.title }}</span>
            <span class="val">−{{ d.total_allocated_amount | money }}</span>
          </div>
        {%- endfor -%}
        <div class="sum-row shipping">
          <span class="label">{{ 'cart.general.shipping' | t | default: 'Delivery' }}</span>
          <span class="val">
            {%- if cart.total_price >= threshold_cents -%}
              {{ 'cart.general.free' | t | default: 'Free' }}
            {%- else -%}
              Calculated at checkout
            {%- endif -%}
          </span>
        </div>
        <div class="sum-total">
          <span class="label">{{ 'cart.general.total' | t | default: 'Total' }}</span>
          <span class="total-val">{{ cart.total_price | money }}</span>
        </div>
        <div class="sum-tax">{{ 'products.product.include_taxes' | t | default: 'Inc. VAT' }}</div>

        <button type="submit" name="checkout" class="checkout-btn">
          {{ 'cart.general.checkout' | t | default: 'Checkout securely' }}
          <span class="arrow">→</span>
        </button>

        {%- if additional_checkout_buttons -%}
          {{ content_for_additional_checkout_buttons }}
        {%- endif -%}
      </aside>
    </div>
  </form>

</div>

{%- endif -%}

<script>
  document.querySelectorAll('[data-cart-qty] button').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      var stepper = btn.parentElement;
      var key = stepper.dataset.cartQty;
      var input = stepper.querySelector('input');
      var v = parseInt(input.value, 10) + parseInt(btn.dataset.step, 10);
      v = Math.max(0, v);
      var res = await fetch('/cart/change.js', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: key, quantity: v })
      });
      if (res.ok) window.location.reload();
    });
  });
  document.querySelectorAll('[data-cart-remove]').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      var key = btn.dataset.cartRemove;
      var res = await fetch('/cart/change.js', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: key, quantity: 0 })
      });
      if (res.ok) window.location.reload();
    });
  });
</script>

{% schema %}
{
  "name": "Cart",
  "settings": []
}
{% endschema %}
