<style>
  #shopify-section-{{ section.id }} .edits {
    background: var(--cream);
    max-width: 1400px; margin: 0 auto;
    padding: 100px 40px;
  }
  #shopify-section-{{ section.id }} .section-head {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 60px; flex-wrap: wrap; gap: 24px;
  }
  #shopify-section-{{ section.id }} .section-head h2 {
    font-family: var(--font-heading); font-weight: 400;
    font-size: clamp(36px, 5vw, 60px);
    line-height: 1.05; letter-spacing: -0.02em;
  }
  #shopify-section-{{ section.id }} .section-head h2 em { font-style: italic; font-weight: 300; color: var(--clay); }
  #shopify-section-{{ section.id }} .section-head .lead { color: var(--ink-soft); max-width: 320px; font-size: 15px; }

  #shopify-section-{{ section.id }} .edit-grid {
    display: grid; grid-template-columns: 1.5fr 1fr 1fr;
    gap: 20px; height: 540px;
  }
  #shopify-section-{{ section.id }} .edit {
    position: relative; overflow: hidden; cursor: pointer; border-radius: 2px; color: var(--cream);
  }
  #shopify-section-{{ section.id }} .edit:hover .edit-bg { transform: scale(1.05); }
  #shopify-section-{{ section.id }} .edit-bg { position: absolute; inset: 0; transition: transform 0.6s; }
  #shopify-section-{{ section.id }} .edit-bg img { width: 100%; height: 100%; object-fit: cover; }
  #shopify-section-{{ section.id }} .edit-bg::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.55), transparent 60%);
  }
  #shopify-section-{{ section.id }} .edit.feature { grid-row: 1 / 3; }
  #shopify-section-{{ section.id }} .edit-content {
    position: absolute; bottom: 32px; left: 32px; right: 32px; z-index: 2;
  }
  #shopify-section-{{ section.id }} .edit.feature .edit-content .name { font-size: 48px; }
  #shopify-section-{{ section.id }} .edit-content .num {
    font-family: var(--font-heading); font-style: italic;
    font-size: 13px; opacity: 0.7; margin-bottom: 8px;
  }
  #shopify-section-{{ section.id }} .edit-content .name {
    font-family: var(--font-heading); font-size: 28px; font-weight: 400; margin-bottom: 8px;
  }
  #shopify-section-{{ section.id }} .edit-content .desc { font-size: 13px; opacity: 0.85; max-width: 320px; line-height: 1.5; }

  /* Fallback gradients per slot */
  #shopify-section-{{ section.id }} .edit[data-slot="0"] .edit-bg { background: linear-gradient(140deg, #2D3326 0%, #4F5B45 60%, #7C8B6F 100%); }
  #shopify-section-{{ section.id }} .edit[data-slot="1"] .edit-bg { background: linear-gradient(140deg, #C97B5E, #8E4426); }
  #shopify-section-{{ section.id }} .edit[data-slot="2"] .edit-bg { background: linear-gradient(140deg, #E8DFD2, #BFB29C); }
  #shopify-section-{{ section.id }} .edit[data-slot="2"] .edit-content { color: var(--ink); }
  #shopify-section-{{ section.id }} .edit[data-slot="2"] .edit-bg::after { background: linear-gradient(to top, rgba(0,0,0,0.1), transparent 60%); }

  @media (max-width: 1024px) {
    #shopify-section-{{ section.id }} .edits { padding: 60px 24px; }
    #shopify-section-{{ section.id }} .edit-grid { grid-template-columns: 1fr; height: auto; gap: 16px; }
    #shopify-section-{{ section.id }} .edit { aspect-ratio: 4 / 3; }
    #shopify-section-{{ section.id }} .edit.feature { aspect-ratio: 16 / 10; grid-row: auto; }
  }
</style>

<section class="edits">
  <div class="section-head">
    {%- if section.settings.heading != blank -%}
      <h2 class="display">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.lead != blank -%}
      <p class="lead">{{ section.settings.lead }}</p>
    {%- endif -%}
  </div>

  <div class="edit-grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link | default: '#' }}" class="edit{% if block.settings.feature %} feature{% endif %}" data-slot="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
        <div class="edit-bg">
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 1000 }}" alt="{{ block.settings.image.alt | default: block.settings.title }}" width="1000" height="{{ 1000 | divided_by: block.settings.image.aspect_ratio | round }}" loading="lazy">
          {%- endif -%}
        </div>
        <div class="edit-content">
          {%- if block.settings.number != blank -%}
            <div class="num">{{ block.settings.number }}</div>
          {%- endif -%}
          <div class="name">{{ block.settings.title }}</div>
          {%- if block.settings.description != blank -%}
            <div class="desc">{{ block.settings.description }}</div>
          {%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Curated edits",
  "max_blocks": 3,
  "settings": [
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>The <em>edits</em></p>" },
    { "type": "text", "id": "lead", "label": "Lead text", "default": "Curated stories for every kind of home — pull together a moment in three pieces." }
  ],
  "blocks": [
    {
      "type": "edit",
      "name": "Edit card",
      "settings": [
        { "type": "text", "id": "number", "label": "Edit number", "default": "Edit · 01" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "image_picker", "id": "image", "label": "Image (optional — falls back to gradient)" },
        { "type": "checkbox", "id": "feature", "label": "Feature card (spans 2 rows on desktop)", "default": false }
      ]
    }
  ],
  "presets": [{
    "name": "Curated edits",
    "category": "Custom",
    "blocks": [
      { "type": "edit", "settings": { "number": "Edit · 01", "title": "Japandi Calm",  "description": "Soft greens, clean lines and quiet stoneware.", "feature": true } },
      { "type": "edit", "settings": { "number": "Edit · 02", "title": "Raw Earth",    "description": "Unglazed terracotta in field tones." } },
      { "type": "edit", "settings": { "number": "Edit · 03", "title": "Bone & Linen", "description": "Pale fibreclay for spring rooms." } }
    ]
  }]
}
{% endschema %}
