<style>
  .search-page { max-width: 1280px; margin: 0 auto; padding: 60px 40px 100px; }
  .search-page .eyebrow { color: var(--clay); margin-bottom: 18px; }
  .search-page h1 {
    font-family: var(--font-heading); font-weight: 400;
    font-size: clamp(40px, 5vw, 56px); line-height: 1; letter-spacing: -0.02em; margin-bottom: 28px;
  }
  .search-page h1 .q { font-style: italic; font-weight: 300; color: var(--clay); }
  .search-form {
    display: flex; align-items: center;
    border: 1px solid var(--ink); background: var(--paper); margin-bottom: 24px;
  }
  .search-form svg { width: 18px; height: 18px; margin-left: 18px; color: var(--muted); flex-shrink: 0; }
  .search-form input {
    flex: 1; background: none; border: none;
    padding: 18px 16px;
    font-family: var(--font-heading); font-style: italic; font-weight: 300;
    font-size: 22px; color: var(--ink); outline: none;
  }
  .search-form button {
    background: var(--ink); color: var(--cream); border: none; cursor: pointer;
    padding: 18px 26px; font-family: inherit; font-size: 12px; font-weight: 500;
    letter-spacing: 0.16em; text-transform: uppercase; white-space: nowrap;
  }
  .search-form button:hover { background: var(--clay-deep); }
  .result-summary { padding: 18px 0; border-top: 1px solid var(--line-soft); font-size: 13.5px; color: var(--ink-soft); }
  .result-summary strong { color: var(--ink); font-weight: 500; }
  .results-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 36px 24px; margin-top: 50px; }
  .search-empty { margin-top: 80px; text-align: center; padding: 60px 20px; }
  .search-empty h2 { font-family: var(--font-heading); font-size: 36px; font-weight: 400; line-height: 1.1; margin-bottom: 14px; }
  .search-empty h2 em { font-style: italic; font-weight: 300; color: var(--clay); }
  .search-empty p { font-family: var(--font-heading); font-style: italic; font-weight: 300; font-size: 18px; color: var(--ink-soft); max-width: 520px; margin: 0 auto 32px; }
  @media (max-width: 1024px) { .search-page { padding: 40px 24px 60px; } .results-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .results-grid { grid-template-columns: 1fr; } }
</style>

<section class="search-page">
  <div class="eyebrow">{{ 'general.search.search' | t | default: 'Search' }}</div>

  {%- if search.performed -%}
    <h1>Results for <span class="q">"{{ search.terms | escape }}"</span></h1>
  {%- else -%}
    <h1>Search the <span class="q">shop</span></h1>
  {%- endif -%}

  <form class="search-form" action="{{ routes.search_url }}" method="get" role="search">
    <svg fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
    <input type="search" name="q" value="{{ search.terms | escape }}"
           placeholder="{{ 'general.search.placeholder' | t | default: 'Search the shop or journal…' }}"
           aria-label="{{ 'general.search.search' | t | default: 'Search' }}"
           autofocus>
    <input type="hidden" name="type" value="product,article,page">
    <button type="submit">{{ 'general.search.search' | t | default: 'Search' }}</button>
  </form>

  {%- if search.performed -%}
    <div class="result-summary">
      <strong>{{ search.results_count }}</strong>
      {%- if search.results_count == 1 -%} result{%- else -%} results{%- endif -%}
      {%- if search.terms != blank %} for <strong>"{{ search.terms | escape }}"</strong>{% endif -%}
    </div>

    {%- if search.results_count == 0 -%}
      <div class="search-empty">
        <h2>No results for <em>"{{ search.terms | escape }}"</em>.</h2>
        <p>{{ 'general.search.no_results' | t | default: 'Nothing matched. Try a different word, or browse the full shop.' }}</p>
        <a href="{{ routes.collections_url }}" class="btn btn-primary">Browse the full shop <span class="arrow">→</span></a>
      </div>
    {%- else -%}
      <div class="results-grid">
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            {% render 'product-card', product: item %}
          {%- elsif item.object_type == 'article' -%}
            <a href="{{ item.url }}" class="product-card">
              <div class="product-card-img" style="background: linear-gradient(140deg, #C97B5E, #6F3A23);">
                {%- if item.image -%}<img src="{{ item.image | image_url: width: 600 }}" alt="{{ item.title | escape }}" width="600" height="{{ 600 | divided_by: item.image.aspect_ratio | round }}" loading="lazy">{%- endif -%}
                <span class="product-card-tag" style="background: var(--ink); color: var(--cream);">Article</span>
              </div>
              <div class="product-card-info">
                <div>
                  <div class="product-card-name">{{ item.title }}</div>
                  <div class="product-card-meta">{{ item.published_at | date: '%-d %b %Y' }}</div>
                </div>
              </div>
            </a>
          {%- elsif item.object_type == 'page' -%}
            <a href="{{ item.url }}" class="product-card">
              <div class="product-card-img" style="background: var(--cream); display: flex; align-items: center; justify-content: center;">
                <svg width="56" height="56" fill="none" stroke="currentColor" stroke-width="1.4" viewBox="0 0 24 24" style="color: var(--clay);"><path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><path d="M14 3v6h6"/></svg>
              </div>
              <div class="product-card-info">
                <div>
                  <div class="product-card-name">{{ item.title }}</div>
                  <div class="product-card-meta">Page</div>
                </div>
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Search results",
  "settings": []
}
{% endschema %}
