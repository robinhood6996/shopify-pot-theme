<style>
  #shopify-section-{{ section.id }} .materials {
    background: var(--cream);
    max-width: 1400px; margin: 0 auto;
    padding: 100px 40px;
  }
  #shopify-section-{{ section.id }} .section-head {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 60px; flex-wrap: wrap; gap: 24px;
  }
  #shopify-section-{{ section.id }} .section-head h2 {
    font-family: var(--font-heading); font-weight: 400;
    font-size: clamp(36px, 5vw, 60px);
    line-height: 1.05; letter-spacing: -0.02em;
    max-width: 700px;
  }
  #shopify-section-{{ section.id }} .section-head h2 em { font-style: italic; font-weight: 300; color: var(--clay); }
  #shopify-section-{{ section.id }} .section-head .lead { color: var(--ink-soft); max-width: 320px; font-size: 15px; }

  #shopify-section-{{ section.id }} .material-grid {
    display: grid; grid-template-columns: repeat(5, 1fr); gap: 20px;
  }
  #shopify-section-{{ section.id }} .material {
    aspect-ratio: 3 / 4; border-radius: 2px;
    position: relative; overflow: hidden; cursor: pointer;
    transition: transform 0.4s;
  }
  #shopify-section-{{ section.id }} .material:hover { transform: translateY(-8px); }
  #shopify-section-{{ section.id }} .material-bg { position: absolute; inset: 0; transition: transform 0.6s; }
  #shopify-section-{{ section.id }} .material:hover .material-bg { transform: scale(1.06); }
  #shopify-section-{{ section.id }} .material-bg img { width: 100%; height: 100%; object-fit: cover; }
  #shopify-section-{{ section.id }} .material-bg::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(26,20,14,0.5), transparent 50%);
  }
  #shopify-section-{{ section.id }} .material-content {
    position: absolute; bottom: 22px; left: 22px; right: 22px;
    color: var(--cream); z-index: 2;
  }
  #shopify-section-{{ section.id }} .material-content .num {
    font-family: var(--font-heading); font-style: italic; font-size: 14px;
    font-weight: 300; opacity: 0.7; margin-bottom: 6px;
  }
  #shopify-section-{{ section.id }} .material-content .name {
    font-family: var(--font-heading); font-size: 22px; font-weight: 400;
  }
  #shopify-section-{{ section.id }} .material-content .count {
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.15em;
    opacity: 0.7; margin-top: 8px;
  }

  /* Fallback gradients per slot when no image */
  #shopify-section-{{ section.id }} .material[data-slot="0"] .material-bg { background: linear-gradient(160deg, #D4A276, #A06840); }
  #shopify-section-{{ section.id }} .material[data-slot="1"] .material-bg { background: linear-gradient(160deg, #C97B5E, #8E4426); }
  #shopify-section-{{ section.id }} .material[data-slot="2"] .material-bg { background: linear-gradient(160deg, #9CA396, #5F6A55); }
  #shopify-section-{{ section.id }} .material[data-slot="3"] .material-bg { background: linear-gradient(160deg, #E8DFD2, #BFB29C); }
  #shopify-section-{{ section.id }} .material[data-slot="4"] .material-bg { background: linear-gradient(160deg, #2D2620, #1A140E); }

  @media (max-width: 1024px) {
    #shopify-section-{{ section.id }} .materials { padding: 60px 24px; }
    #shopify-section-{{ section.id }} .material-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    #shopify-section-{{ section.id }} .material-grid { grid-template-columns: 1fr 1fr; }
  }
</style>

<section class="materials">
  <div class="section-head">
    {%- if section.settings.heading != blank -%}
      <h2 class="display">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.lead != blank -%}
      <p class="lead">{{ section.settings.lead }}</p>
    {%- endif -%}
  </div>

  <div class="material-grid">
    {%- for block in section.blocks -%}
      {%- assign coll = block.settings.collection -%}
      <a href="{%- if coll != blank -%}{{ coll.url }}{%- else -%}#{%- endif -%}" class="material" data-slot="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
        <div class="material-bg">
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.image.alt | default: block.settings.label }}" width="600" height="{{ 600 | divided_by: block.settings.image.aspect_ratio | round }}" loading="lazy">
          {%- elsif coll and coll.image != blank -%}
            <img src="{{ coll.image | image_url: width: 600 }}" alt="{{ coll.title | escape }}" width="600" height="{{ 600 | divided_by: coll.image.aspect_ratio | round }}" loading="lazy">
          {%- endif -%}
        </div>
        <div class="material-content">
          <div class="num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</div>
          <div class="name">{{ block.settings.label | default: coll.title | default: 'Material' }}</div>
          <div class="count">
            {%- if coll != blank -%}
              {{ coll.products_count }} pieces
            {%- else -%}
              {{ block.settings.count_text }}
            {%- endif -%}
          </div>
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Shop by material",
  "max_blocks": 5,
  "settings": [
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Shop by <em>material</em></p>" },
    { "type": "text", "id": "lead", "label": "Lead text", "default": "From soft fibreclay to hand-thrown stoneware — choose the texture that suits your home." }
  ],
  "blocks": [
    {
      "type": "material",
      "name": "Material card",
      "settings": [
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "collection", "id": "collection", "label": "Linked collection" },
        { "type": "image_picker", "id": "image", "label": "Image (optional)" },
        { "type": "text", "id": "count_text", "label": "Count fallback (if no collection)", "default": "0 pieces" }
      ]
    }
  ],
  "presets": [{
    "name": "Shop by material",
    "category": "Custom",
    "blocks": [
      { "type": "material", "settings": { "label": "Stoneware",  "count_text": "28 pieces" } },
      { "type": "material", "settings": { "label": "Terracotta", "count_text": "14 pieces" } },
      { "type": "material", "settings": { "label": "Concrete",   "count_text": "19 pieces" } },
      { "type": "material", "settings": { "label": "Fibreclay",  "count_text": "22 pieces" } },
      { "type": "material", "settings": { "label": "Metal",      "count_text": "11 pieces" } }
    ]
  }]
}
{% endschema %}
