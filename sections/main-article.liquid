<style>
  .article-hero {
    max-width: 880px; margin: 0 auto;
    padding: 60px 40px 40px; text-align: center;
  }
  .article-hero .eyebrow { color: var(--clay); margin-bottom: 30px; }
  .article-hero h1 {
    font-family: var(--font-heading); font-weight: 400;
    font-size: clamp(42px, 6vw, 76px);
    margin-bottom: 28px; letter-spacing: -0.025em; line-height: 1.05;
  }
  .article-hero h1 em { font-style: italic; font-weight: 300; color: var(--clay); }
  .article-dek {
    font-family: var(--font-heading); font-style: italic; font-weight: 300;
    font-size: 22px; line-height: 1.45; color: var(--ink-soft);
    max-width: 700px; margin: 0 auto 50px;
  }
  .article-meta {
    display: flex; align-items: center; justify-content: center;
    gap: 30px; padding-top: 30px; border-top: 1px solid var(--line);
    flex-wrap: wrap; font-size: 13px; color: var(--ink-soft);
  }
  .article-meta-author { display: flex; align-items: center; gap: 12px; }
  .author-avatar {
    width: 36px; height: 36px; border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, #C68B5C, #5C2A14);
  }
  .article-meta-author strong { display: block; font-family: var(--font-heading); font-size: 14px; color: var(--ink); font-weight: 400; }
  .article-meta .divider { width: 1px; height: 24px; background: var(--line); }

  .article-image { max-width: 1200px; margin: 30px auto 0; padding: 0 40px; }
  .article-image img { width: 100%; aspect-ratio: 16/9; object-fit: cover; border-radius: 2px; }

  .article-body {
    max-width: 720px; margin: 80px auto 0; padding: 0 40px;
    font-size: 17px; line-height: 1.8; color: var(--ink);
  }
  .article-body p { margin-bottom: 22px; }
  .article-body > p:first-of-type::first-letter {
    font-family: var(--font-heading); font-style: italic; font-weight: 300;
    font-size: 70px; line-height: 0.85;
    float: left; margin: 6px 12px 0 0; color: var(--clay);
  }
  .article-body h2 {
    font-family: var(--font-heading); font-size: 36px; font-weight: 400;
    line-height: 1.15; margin: 60px 0 24px; letter-spacing: -0.015em;
  }
  .article-body h2 em { font-style: italic; font-weight: 300; color: var(--clay); }
  .article-body h3 { font-family: var(--font-heading); font-size: 22px; font-weight: 500; line-height: 1.3; margin: 36px 0 14px; }
  .article-body strong { font-weight: 500; color: var(--ink); }
  .article-body em { font-family: var(--font-heading); font-style: italic; font-weight: 300; }
  .article-body a { color: var(--clay); border-bottom: 1px solid var(--clay); padding-bottom: 1px; }
  .article-body a:hover { opacity: 0.7; }
  .article-body ul, .article-body ol { margin: 0 0 26px 24px; }
  .article-body li { margin-bottom: 8px; padding-left: 6px; }
  .article-body img { border-radius: 2px; margin: 30px 0; }

  .article-tags {
    max-width: 720px; margin: 50px auto;
    padding: 24px 40px;
    border-top: 1px solid var(--line); border-bottom: 1px solid var(--line);
    display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
  }
  .article-tags .label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.15em; color: var(--muted); font-weight: 500; }
  .article-tags a {
    border: 1px solid var(--line); padding: 6px 14px; border-radius: 100px;
    font-size: 12.5px; color: var(--ink-soft); transition: all 0.2s;
  }
  .article-tags a:hover { background: var(--ink); color: var(--cream); border-color: var(--ink); }

  .article-author {
    max-width: 720px; margin: 70px auto 0; padding: 40px;
    background: var(--ink); color: var(--cream); border-radius: 4px;
    display: grid; grid-template-columns: 80px 1fr; gap: 28px; align-items: center;
  }
  .article-author .av { width: 80px; height: 80px; border-radius: 50%; background: radial-gradient(circle at 35% 30%, #E5C9A8, #8E4426); }
  .article-author .label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.18em; color: var(--clay); margin-bottom: 8px; font-weight: 500; }
  .article-author h3 { font-family: var(--font-heading); font-size: 28px; font-weight: 400; line-height: 1.15; margin-bottom: 10px; }
  .article-author h3 em { font-style: italic; font-weight: 300; color: var(--clay); }
  .article-author p { font-size: 14.5px; line-height: 1.65; color: var(--bone); max-width: 600px; }

  .related-articles {
    max-width: 1280px; margin: 80px auto 0; padding: 80px 40px;
    background: var(--cream); border-top: 1px solid var(--line);
  }
  .related-articles h2 { font-family: var(--font-heading); font-size: clamp(28px, 3.5vw, 40px); font-weight: 400; line-height: 1.1; margin-bottom: 36px; }
  .related-articles h2 em { font-style: italic; font-weight: 300; color: var(--clay); }
  .related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; }
  .related-post { cursor: pointer; text-decoration: none; color: inherit; }
  .related-post-img { aspect-ratio: 4 / 3; margin-bottom: 18px; overflow: hidden; background: var(--cream-deep); }
  .related-post-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
  .related-post:hover .related-post-img img { transform: scale(1.05); }
  .related-post .meta { font-size: 11px; text-transform: uppercase; letter-spacing: 0.15em; color: var(--clay); margin-bottom: 10px; }
  .related-post h3 { font-family: var(--font-heading); font-size: 22px; font-weight: 400; line-height: 1.25; margin-bottom: 8px; transition: color 0.2s; }
  .related-post:hover h3 { color: var(--clay); }
  .related-post p { color: var(--ink-soft); font-size: 14px; line-height: 1.6; }

  @media (max-width: 1024px) {
    .article-hero { padding: 40px 24px 30px; }
    .article-image { padding: 0 24px; }
    .article-body { padding: 0 24px; }
    .article-tags { padding: 18px 24px; }
    .article-author { grid-template-columns: 1fr; padding: 30px; }
    .related-articles { padding: 60px 24px; }
    .related-grid { grid-template-columns: 1fr; }
  }
</style>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ article.title | json }},
  "datePublished": "{{ article.published_at | date: '%Y-%m-%d' }}",
  {% if article.author %}"author": {"@type": "Person", "name": {{ article.author | json }}},{% endif %}
  "publisher": {"@type": "Organization", "name": {{ shop.name | json }}}
}
</script>

<nav class="breadcrumb">
  <a href="{{ routes.root_url }}">Home</a><span class="sep">/</span>
  <a href="{{ blog.url }}">{{ blog.title }}</a><span class="sep">/</span>
  <span class="current">{{ article.title }}</span>
</nav>

<article>
  <section class="article-hero">
    <div class="eyebrow">{{ article.tags | first | default: blog.title }}</div>
    <h1>{{ article.title }}</h1>
    {%- if article.excerpt != blank -%}
      <p class="article-dek">{{ article.excerpt | strip_html }}</p>
    {%- endif -%}
    <div class="article-meta">
      {%- if article.author -%}
        <div class="article-meta-author">
          <div class="author-avatar"></div>
          <div><strong>{{ article.author }}</strong></div>
        </div>
        <div class="divider"></div>
      {%- endif -%}
      <span><strong>{{ article.published_at | date: "%-d %B %Y" }}</strong></span>
      {%- assign mins = article.content | strip_html | split: ' ' | size | divided_by: 200 | at_least: 1 -%}
      <div class="divider"></div>
      <span>{{ mins }} minute read</span>
    </div>
  </section>

  {%- if article.image -%}
    <div class="article-image">
      <img src="{{ article.image | image_url: width: 1600 }}" alt="{{ article.image.alt | default: article.title | escape }}" width="1600" height="{{ 1600 | divided_by: article.image.aspect_ratio | round }}" loading="eager">
    </div>
  {%- endif -%}

  <div class="article-body">{{ article.content }}</div>

  {%- if article.tags.size > 0 -%}
    <div class="article-tags">
      <span class="label">Filed under</span>
      {%- for tag in article.tags -%}
        <a href="{{ blog.url }}/tagged/{{ tag | handle }}">{{ tag }}</a>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- if article.author and article.metafields.custom.author_bio != blank -%}
    <div class="article-author">
      <div class="av"></div>
      <div>
        <div class="label">Written by</div>
        <h3>{{ article.author | replace: ' ', ' <em>' | append: '</em>' }}</h3>
        <p>{{ article.metafields.custom.author_bio }}</p>
      </div>
    </div>
  {%- endif -%}
</article>

{%- if blog.articles.size > 1 -%}
  <section class="related-articles">
    <h2>Keep <em>reading</em>.</h2>
    <div class="related-grid">
      {%- assign other = 0 -%}
      {%- for related in blog.articles -%}
        {%- if related.id != article.id and other < 3 -%}
          <a href="{{ related.url }}" class="related-post">
            <div class="related-post-img">
              {%- if related.image -%}
                <img src="{{ related.image | image_url: width: 600 }}" alt="{{ related.image.alt | default: related.title | escape }}" width="600" height="{{ 600 | divided_by: related.image.aspect_ratio | round }}" loading="lazy">
              {%- endif -%}
            </div>
            <div class="meta">{{ related.tags | first | default: blog.title }}</div>
            <h3>{{ related.title }}</h3>
            {%- if related.excerpt != blank -%}
              <p>{{ related.excerpt | strip_html | truncate: 120 }}</p>
            {%- endif -%}
          </a>
          {%- assign other = other | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Article",
  "settings": []
}
{% endschema %}
