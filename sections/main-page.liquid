<style>
  .page-shell { max-width: 760px; margin: 0 auto; padding: 80px 40px; }
  .page-shell .eyebrow { color: var(--clay); margin-bottom: 22px; }
  .page-shell h1 {
    font-family: var(--font-heading); font-weight: 400;
    font-size: clamp(48px, 6vw, 84px); line-height: 0.95; letter-spacing: -0.02em; margin-bottom: 40px;
  }
  .page-shell h1 em { font-style: italic; font-weight: 300; color: var(--clay); }
  .page-content { font-size: 17px; line-height: 1.8; color: var(--ink); }
  .page-content p { margin-bottom: 22px; }
  .page-content h2 {
    font-family: var(--font-heading); font-size: 32px; font-weight: 400;
    line-height: 1.15; margin: 50px 0 20px; letter-spacing: -0.015em;
  }
  .page-content h2 em { font-style: italic; font-weight: 300; color: var(--clay); }
  .page-content h3 { font-family: var(--font-heading); font-size: 22px; font-weight: 500; line-height: 1.3; margin: 36px 0 14px; }
  .page-content strong { font-weight: 500; }
  .page-content em { font-family: var(--font-heading); font-style: italic; font-weight: 300; }
  .page-content a { color: var(--clay); border-bottom: 1px solid var(--clay); padding-bottom: 1px; }
  .page-content ul, .page-content ol { margin: 0 0 22px 24px; }
  .page-content li { margin-bottom: 8px; }
  @media (max-width: 1024px) { .page-shell { padding: 50px 24px; } }
</style>

<nav class="breadcrumb">
  <a href="{{ routes.root_url }}">Home</a><span class="sep">/</span>
  <span class="current">{{ page.title }}</span>
</nav>

<article class="page-shell">
  <div class="eyebrow">{{ page.template_suffix | default: 'Page' | capitalize }}</div>
  <h1>{{ page.title }}</h1>
  <div class="page-content">
    {{ page.content }}
  </div>
</article>

{% schema %}
{
  "name": "Page",
  "settings": []
}
{% endschema %}
